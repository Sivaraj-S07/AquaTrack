# ── AquaTrack Frontend – Environment Variables ──────────────────
# Copy this file to .env.local for local development.
# For Vercel: set these in Project → Settings → Environment Variables

# URL of your deployed Render backend (no trailing slash)
# Example: https://aquatrack-backend.onrender.com/api
REACT_APP_API_URL=https://your-backend.onrender.com/api
