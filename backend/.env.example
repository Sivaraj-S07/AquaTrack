# ── AquaTrack Backend – Environment Variables ───────────────────
# Copy this file to .env and fill in your values before running.

# Server
PORT=5000

# JWT
JWT_SECRET=replace_with_long_random_secret_min_32_chars
JWT_EXPIRES_IN=7d

# CORS – comma-separated list of allowed frontend origins
# For Vercel: https://your-app.vercel.app,https://aquatrack.yourdomain.com
CLIENT_URL=http://localhost:3000

# Admin credentials (set a strong password!)
ADMIN_EMAIL=admin@aquatrack.com
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=Administrator
